---
import Layout from '../components/Layout.astro';
import AccountCard from '../components/AccountCard.astro';
import TransactionTable from '../components/TransactionTable.astro';
import BudgetChart from '../components/BudgetChart.astro';
import FileUpload from '../components/FileUpload.astro';

// Mock data - in real app, this would come from API
const accounts = [
  {
    id: '1',
    name: 'Primary Checking',
    account_type: 'checking',
    institution: 'Chase Bank',
    current_balance: 5420.50
  },
  {
    id: '2',
    name: 'Savings Account',
    account_type: 'savings',
    institution: 'Chase Bank',
    current_balance: 15800.00
  }
];

const recentTransactions = [
  {
    id: '1',
    date: '2025-07-06',
    description: 'Grocery Store Purchase',
    amount: -85.43,
    merchant: 'Whole Foods'
  },
  {
    id: '2',
    date: '2025-07-05',
    description: 'Salary Deposit',
    amount: 3500.00,
    merchant: 'Company Inc'
  }
];
---

<Layout title="Banking Dashboard">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <div class="flex space-x-3">
        <a href="/docs" class="btn-secondary">
          <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
          Documentation
        </a>
        <button onclick="showUploadModal()" class="btn-primary">
          Upload Transactions
        </button>
      </div>
    </div>
    
    <!-- Account Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {accounts.map((account) => (
        <AccountCard account={account} />
      ))}
    </div>
    
    <!-- Budget Overview -->
    <BudgetChart />
    
    <!-- Recent Transactions -->
    <TransactionTable transactions={recentTransactions} />
  </div>
  
  <!-- File Upload Modal -->
  <FileUpload />
</Layout>

<style>
  .btn-primary {
    @apply bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors;
  }
  
  .btn-secondary {
    @apply bg-gray-200 text-gray-800 px-4 py-2 rounded-md hover:bg-gray-300 transition-colors;
  }
</style>

<script src="../scripts/api.js"></script>