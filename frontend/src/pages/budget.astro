---
import Layout from '../components/Layout.astro';
---

<Layout title="Budget - Banking App">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center space-y-4 sm:space-y-0">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Budget Analysis</h1>
        <p class="text-gray-600">Analyze your spending patterns and manage recurring expenses</p>
      </div>
      <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-3">
        <button onclick="detectRecurringTransactions()" class="btn-secondary">
          <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          Detect Recurring
        </button>
        <a href="/docs#budgeting" class="btn-secondary">
          <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
          Guide
        </a>
      </div>
    </div>

    <!-- Migration Notice Banner -->
    <div id="migration-notice" class="hidden bg-yellow-50 border border-yellow-200 rounded-lg p-4">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 15.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800">Database Migration Required</h3>
          <div class="mt-1 text-sm text-yellow-700">
            <p>The recurring transaction feature requires a database update. Please restart the application to enable all budget analysis features.</p>
          </div>
          <div class="mt-3">
            <button onclick="hideMigrationNotice()" class="text-sm font-medium text-yellow-800 hover:text-yellow-600 underline">
              Dismiss
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Monthly Analysis Section -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 sm:mb-0">Monthly Analysis</h2>
        <div class="flex items-center space-x-3">
          <label class="text-sm font-medium text-gray-700">Select Month:</label>
          <select id="month-selector" class="border border-gray-300 rounded-md px-3 py-2 text-sm" onchange="loadMonthlyAnalysis()">
            <option value="">Select a month...</option>
          </select>
        </div>
      </div>

      <!-- Monthly Summary Cards -->
      <div id="monthly-summary" class="hidden">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 border border-blue-200">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-blue-900">Total Expenses</p>
                <p id="total-expenses" class="text-2xl font-bold text-blue-600">$0.00</p>
              </div>
            </div>
          </div>

          <div class="bg-green-50 rounded-lg p-4 border border-green-200">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-green-900">Recurring Expenses</p>
                <p id="recurring-expenses" class="text-2xl font-bold text-green-600">$0.00</p>
                <p id="recurring-percentage" class="text-xs text-green-700">0% of total</p>
              </div>
            </div>
          </div>

          <div class="bg-orange-50 rounded-lg p-4 border border-orange-200">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-orange-900">Variable Expenses</p>
                <p id="variable-expenses" class="text-2xl font-bold text-orange-600">$0.00</p>
                <p id="variable-percentage" class="text-xs text-orange-700">0% of total</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Expense Breakdown Chart -->
        <div class="mb-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Recurring vs Variable Expenses</h3>
          <div class="relative">
            <canvas id="expense-chart" width="400" height="200"></canvas>
          </div>
        </div>

        <!-- Category Breakdown -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Recurring Categories -->
          <div>
            <h3 class="text-lg font-medium text-gray-900 mb-4">Recurring Expenses by Category</h3>
            <div id="recurring-categories" class="space-y-3">
              <!-- Categories will be populated here -->
            </div>
          </div>

          <!-- Variable Categories -->
          <div>
            <h3 class="text-lg font-medium text-gray-900 mb-4">Variable Expenses by Category</h3>
            <div id="variable-categories" class="space-y-3">
              <!-- Categories will be populated here -->
            </div>
          </div>
        </div>
      </div>

      <!-- No Data State -->
      <div id="no-data-state" class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Select a Month to Analyze</h3>
        <p class="text-gray-500 mb-4">Choose a month from the dropdown to see your spending analysis.</p>
        <p class="text-sm text-gray-400">Make sure to detect recurring transactions first for better insights.</p>
      </div>
    </div>

    <!-- Recurring Patterns Section -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900">Recurring Transaction Patterns</h2>
        <button onclick="loadRecurringPatterns()" class="btn-secondary text-sm">
          <svg class="w-4 h-4 mr-1 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          Refresh
        </button>
      </div>

      <div id="recurring-patterns-container">
        <!-- Patterns will be loaded here -->
      </div>
    </div>
  </div>

  <style>
    .btn-primary {
      @apply bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors font-medium;
    }
    
    .btn-secondary {
      @apply bg-gray-200 text-gray-800 px-4 py-2 rounded-md hover:bg-gray-300 transition-colors font-medium;
    }

    .category-bar {
      transition: width 0.3s ease-in-out;
    }
  </style>

  <script>
    let currentAnalysis = null;
    let expenseChart = null;

    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
      loadAvailableMonths();
      loadRecurringPatterns();
    });

    async function loadAvailableMonths() {
      try {
        const response = await window.api.request('/budgets/available-months');
        const monthSelector = document.getElementById('month-selector');
        
        monthSelector.innerHTML = '<option value="">Select a month...</option>';
        
        if (response.success && response.months.length > 0) {
          response.months.forEach(month => {
            const option = document.createElement('option');
            option.value = `${month.year}-${month.month}`;
            option.textContent = month.display;
            monthSelector.appendChild(option);
          });
          
          // Auto-select the most recent month
          if (response.months.length > 0) {
            monthSelector.value = `${response.months[0].year}-${response.months[0].month}`;
            loadMonthlyAnalysis();
          }
        }
      } catch (error) {
        console.error('Failed to load available months:', error);
      }
    }

    async function loadMonthlyAnalysis() {
      const monthSelector = document.getElementById('month-selector');
      const selectedMonth = monthSelector.value;
      
      if (!selectedMonth) {
        showNoDataState();
        return;
      }

      const [year, month] = selectedMonth.split('-').map(Number);

      try {
        const response = await window.api.request(`/budgets/monthly-analysis/${year}/${month}`);
        
        if (response.success) {
          currentAnalysis = response.analysis;
          displayMonthlyAnalysis(currentAnalysis);
        } else {
          showError('Failed to load monthly analysis');
        }
      } catch (error) {
        console.error('Failed to load monthly analysis:', error);
        showError('Failed to load monthly analysis');
      }
    }

    function displayMonthlyAnalysis(analysis) {
      document.getElementById('no-data-state').classList.add('hidden');
      document.getElementById('monthly-summary').classList.remove('hidden');

      // Update summary cards
      document.getElementById('total-expenses').textContent = formatCurrency(analysis.total_expenses);
      document.getElementById('recurring-expenses').textContent = formatCurrency(analysis.recurring.total);
      document.getElementById('recurring-percentage').textContent = `${analysis.recurring.percentage}% of total`;
      document.getElementById('variable-expenses').textContent = formatCurrency(analysis.non_recurring.total);
      document.getElementById('variable-percentage').textContent = `${analysis.non_recurring.percentage}% of total`;

      // Update chart
      updateExpenseChart(analysis);

      // Update category breakdowns
      displayCategoryBreakdown('recurring-categories', analysis.recurring.by_category, analysis.recurring.total);
      displayCategoryBreakdown('variable-categories', analysis.non_recurring.by_category, analysis.non_recurring.total);
    }

    function updateExpenseChart(analysis) {
      const canvas = document.getElementById('expense-chart');
      const ctx = canvas.getContext('2d');
      
      // Clear previous chart
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // Simple bar chart
      const recurring = analysis.recurring.total;
      const variable = analysis.non_recurring.total;
      const total = recurring + variable;
      
      if (total === 0) return;
      
      const barHeight = 60;
      const barY = (canvas.height - barHeight) / 2;
      const recurringWidth = (recurring / total) * (canvas.width - 40);
      const variableWidth = (variable / total) * (canvas.width - 40);
      
      // Draw recurring bar
      ctx.fillStyle = '#10B981';
      ctx.fillRect(20, barY, recurringWidth, barHeight);
      
      // Draw variable bar
      ctx.fillStyle = '#F59E0B';
      ctx.fillRect(20 + recurringWidth, barY, variableWidth, barHeight);
      
      // Add labels
      ctx.fillStyle = '#374151';
      ctx.font = '14px Arial';
      ctx.fillText('Recurring', 20, barY - 10);
      ctx.fillText('Variable', 20 + recurringWidth, barY - 10);
      
      // Add percentages
      ctx.fillStyle = '#FFFFFF';
      ctx.font = 'bold 12px Arial';
      ctx.textAlign = 'center';
      if (recurringWidth > 50) {
        ctx.fillText(`${analysis.recurring.percentage}%`, 20 + recurringWidth / 2, barY + barHeight / 2 + 4);
      }
      if (variableWidth > 50) {
        ctx.fillText(`${analysis.non_recurring.percentage}%`, 20 + recurringWidth + variableWidth / 2, barY + barHeight / 2 + 4);
      }
      ctx.textAlign = 'start';
    }

    function displayCategoryBreakdown(containerId, categories, total) {
      const container = document.getElementById(containerId);
      container.innerHTML = '';

      if (Object.keys(categories).length === 0) {
        container.innerHTML = '<p class="text-gray-500 text-sm">No transactions in this category</p>';
        return;
      }

      // Sort categories by amount
      const sortedCategories = Object.entries(categories).sort((a, b) => b[1] - a[1]);

      sortedCategories.forEach(([categoryName, amount]) => {
        const percentage = total > 0 ? (amount / total * 100) : 0;
        
        const categoryElement = document.createElement('div');
        categoryElement.className = 'flex items-center justify-between p-3 bg-gray-50 rounded-md';
        categoryElement.innerHTML = `
          <div class="flex-1">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium text-gray-900">${categoryName}</span>
              <span class="text-sm font-medium text-gray-900">${formatCurrency(amount)}</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="category-bar h-2 rounded-full" style="width: ${percentage}%; background-color: ${getColorForCategory(categoryName)};"></div>
            </div>
            <div class="text-xs text-gray-500 mt-1">${percentage.toFixed(1)}% of ${containerId.includes('recurring') ? 'recurring' : 'variable'} expenses</div>
          </div>
        `;
        container.appendChild(categoryElement);
      });
    }

    function getColorForCategory(categoryName) {
      const colors = {
        'Food & Dining': '#10B981',
        'Transportation': '#3B82F6',
        'Shopping': '#8B5CF6',
        'Entertainment': '#F59E0B',
        'Bills & Utilities': '#EF4444',
        'Healthcare': '#EC4899',
        'Uncategorized': '#6B7280'
      };
      return colors[categoryName] || '#6B7280';
    }

    async function detectRecurringTransactions() {
      try {
        console.log('Starting recurring detection...');
        console.log('API client available:', !!window.api);
        
        const button = document.querySelector('button[onclick="detectRecurringTransactions()"]');
        const originalText = button.innerHTML;
        button.innerHTML = '<svg class="animate-spin w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>Detecting...';
        button.disabled = true;

        console.log('Making API request to /budgets/detect-recurring');
        const response = await window.api.request('/budgets/detect-recurring', {
          method: 'POST'
        });
        console.log('API response received:', response);

        if (response.success) {
          alert(`Successfully detected ${response.recurring_transactions} recurring transactions across ${response.patterns_found} patterns!`);
          loadRecurringPatterns();
          loadMonthlyAnalysis(); // Refresh the current analysis
        } else {
          console.error('Detection failed response:', response);
          alert('Detection failed: ' + (response.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Failed to detect recurring transactions:', error);
        console.error('Error details:', error.message);
        alert('Failed to detect recurring transactions: ' + error.message);
      } finally {
        const button = document.querySelector('button[onclick="detectRecurringTransactions()"]');
        button.innerHTML = originalText;
        button.disabled = false;
      }
    }

    async function loadRecurringPatterns() {
      try {
        console.log('Loading recurring patterns...');
        const response = await window.api.request('/budgets/recurring-patterns');
        console.log('Patterns response received:', response);
        
        if (response.success) {
          displayRecurringPatterns(response.patterns, response.database_ready);
          
          // If database is not ready, show migration notice and disable the detect button
          if (!response.database_ready) {
            const migrationNotice = document.getElementById('migration-notice');
            migrationNotice.classList.remove('hidden');
            
            const detectButton = document.querySelector('button[onclick="detectRecurringTransactions()"]');
            detectButton.disabled = true;
            detectButton.innerHTML = '⚠️ Migration Required';
            detectButton.classList.add('opacity-50', 'cursor-not-allowed');
          }
        } else {
          console.error('Load patterns failed response:', response);
          showError('Failed to load recurring patterns: ' + (response.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Failed to load recurring patterns:', error);
        console.error('Error details:', error.message);
        showError('Failed to load recurring patterns: ' + error.message);
      }
    }

    function displayRecurringPatterns(patterns, databaseReady = true) {
      const container = document.getElementById('recurring-patterns-container');
      
      if (!databaseReady) {
        container.innerHTML = `
          <div class="text-center py-8">
            <svg class="mx-auto h-8 w-8 text-yellow-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 15.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
            <p class="text-gray-700 font-medium">Database Migration Required</p>
            <p class="text-sm text-gray-500 mt-1">The recurring transaction feature requires a database update.</p>
            <p class="text-sm text-gray-500 mt-2">Please restart the application or run the migration script to enable this feature.</p>
          </div>
        `;
        return;
      }
      
      if (patterns.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8">
            <svg class="mx-auto h-8 w-8 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            <p class="text-gray-500">No recurring patterns detected yet.</p>
            <p class="text-sm text-gray-400 mt-1">Click "Detect Recurring" to analyze your transactions.</p>
          </div>
        `;
        return;
      }

      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Average Amount</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Frequency</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Occurrences</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Next Predicted</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              ${patterns.map(pattern => `
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">${pattern.description}</div>
                    ${pattern.merchant ? `<div class="text-sm text-gray-500">${pattern.merchant}</div>` : ''}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full" style="background-color: ${getColorForCategory(pattern.category_name)}20; color: ${getColorForCategory(pattern.category_name)};">
                      ${pattern.category_name}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    ${formatCurrency(pattern.avg_amount)}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    Every ${pattern.frequency_days} days
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    ${pattern.total_occurrences}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    ${pattern.next_predicted ? new Date(pattern.next_predicted).toLocaleDateString() : 'N/A'}
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;
    }

    function showNoDataState() {
      document.getElementById('monthly-summary').classList.add('hidden');
      document.getElementById('no-data-state').classList.remove('hidden');
    }

    function showError(message) {
      alert(message);
    }

    function formatCurrency(amount) {
      return new Intl.NumberFormat('en-US', { 
        style: 'currency', 
        currency: 'USD' 
      }).format(amount || 0);
    }

    window.hideMigrationNotice = function() {
      document.getElementById('migration-notice').classList.add('hidden');
    };
  </script>

  <script src="../scripts/api.js"></script>
</Layout>