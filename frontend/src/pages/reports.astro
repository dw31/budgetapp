---
import Layout from '../components/Layout.astro';
---

<Layout title="Reports - Banking App">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-bold text-gray-900">Financial Reports</h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-6 rounded-lg shadow hover:shadow-md transition-shadow">
        <div class="flex items-center mb-4">
          <svg class="w-8 h-8 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900">Cash Flow</h3>
        </div>
        <p class="text-gray-600 mb-4">View income vs expenses over time</p>
        <button class="btn-secondary w-full" onclick="alert('Coming soon')">Generate Report</button>
      </div>

      <div class="bg-white p-6 rounded-lg shadow hover:shadow-md transition-shadow">
        <div class="flex items-center mb-4">
          <svg class="w-8 h-8 text-green-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900">Net Worth</h3>
        </div>
        <p class="text-gray-600 mb-4">Calculate total assets minus liabilities</p>
        <button class="btn-secondary w-full" onclick="alert('Coming soon')">Generate Report</button>
      </div>

      <div class="bg-white p-6 rounded-lg shadow hover:shadow-md transition-shadow">
        <div class="flex items-center mb-4">
          <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900">Spending Analysis</h3>
        </div>
        <p class="text-gray-600 mb-4">Breakdown spending by category</p>
        <button class="btn-secondary w-full" onclick="alert('Coming soon')">Generate Report</button>
      </div>
    </div>

    <div class="text-center py-12 text-gray-500">
      <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      <h3 class="text-lg font-medium text-gray-900 mb-2">Advanced Reporting</h3>
      <p class="text-gray-500 mb-4">Detailed financial reports will be implemented in a future update.</p>
      <p class="text-sm text-gray-400">Focus on managing accounts and transactions for now.</p>
    </div>
  </div>
</Layout>

<style>
  .btn-secondary {
    @apply bg-gray-200 text-gray-800 px-4 py-2 rounded-md hover:bg-gray-300 transition-colors;
  }
</style>

<script src="../scripts/api.js"></script>